# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key (used in API routes only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Business Config ────────────────────────────────────────────
# The default business ID from your businesses table
DEFAULT_BUSINESS_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEFAULT_BUSINESS_ID=00000000-0000-0000-0000-000000000001

# Operator email (used for operator login via Supabase Auth)
NEXT_PUBLIC_OPERATOR_EMAIL=operator@yoursalon.com

# ─── App Config ───────────────────────────────────────────────
# Your production domain (used in QR codes)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
